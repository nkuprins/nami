# Copy this file to .env and fill in your values.

# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/baltnami
DB_USERNAME=postgres
DB_PASSWORD=changeme

# JWT signing key — must be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-must-be-at-least-32-characters-long

# AWS S3 (for photo/floor-plan uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-north-1
S3_BUCKET=your-s3-bucket-name

# CloudFront CDN URL (serves S3 objects publicly)
CDN_URL=https://your-cloudfront-distribution.cloudfront.net

# Resend (transactional email)
RESEND_API_KEY=re_your_api_key

# Frontend origin — used for CORS and email links
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
